\@writefile{toc}{\contentsline {paragraph}{FLOPs breakdown: origin of the $7{\times }$ advantage (Small vs.\ B0).}{6}{section*.31}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces GFLOPs, CPU latency and throughput (batch\nonbreakingspace 1, desktop: i7-10700K; mobile: Samsung Galaxy S24, Snapdragon\nonbreakingspace 8\nonbreakingspace Gen\nonbreakingspace 3 CPU). \textbf  {SFZ-Large wall-clock} (89\,ms) approximates B4 (87\,ms) despite $4.3{\times }$ fewer FLOPs: at batch=1, TLA bilinear-interpolation dispatch and three-stream memory bandwidth dominate over FLOPs; the compute advantage is realised at higher batch sizes. EfficientGCN S24 not measured: dynamic adjacency ($O(V^2\!C)$) prevents static TorchScript export without non-trivial graph surgery.}}{7}{table.caption.29}\protected@file@percent }
\newlabel{tab:gflops}{{4}{7}{GFLOPs, CPU latency and throughput (batch~1, desktop: i7-10700K; mobile: Samsung Galaxy S24, Snapdragon~8~Gen~3 CPU). \textbf {SFZ-Large wall-clock} (89\,ms) approximates B4 (87\,ms) despite $4.3{\times }$ fewer FLOPs: at batch=1, TLA bilinear-interpolation dispatch and three-stream memory bandwidth dominate over FLOPs; the compute advantage is realised at higher batch sizes. EfficientGCN S24 not measured: dynamic adjacency ($O(V^2\!C)$) prevents static TorchScript export without non-trivial graph surgery}{table.caption.29}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Accuracy per GFLOP (Acc/GFLOP) on NTU-60 X-Sub. Higher = more compute-efficient. Limited to models with reported FLOPs.}}{7}{table.caption.30}\protected@file@percent }
