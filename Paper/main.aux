\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Accuracy--GFLOPs Pareto frontier on NTU-60 X-Sub (GFLOPs axis only; see Table\nonbreakingspace \ref {tab:variants} for parameter counts). Dashed line = Pareto-optimal set. SFZ dominates at all compute budgets: Nano uses $21{\times }$ fewer FLOPs than EfficientGCN-B0 while remaining Pareto-optimal; Large advances the frontier at 1.95\,G.}}{7}{figure.caption.32}\protected@file@percent }
\newlabel{fig:pareto}{{6}{7}{Accuracy--GFLOPs Pareto frontier on NTU-60 X-Sub (GFLOPs axis only; see Table~\ref {tab:variants} for parameter counts). Dashed line = Pareto-optimal set. SFZ dominates at all compute budgets: Nano uses $21{\times }$ fewer FLOPs than EfficientGCN-B0 while remaining Pareto-optimal; Large advances the frontier at 1.95\,G}{figure.caption.32}{}}
